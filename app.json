{
  "expo": {
    "name": "Chronr",
    "slug": "chronr",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F4F4F4"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "xyz.spacr.chronr",
      "infoPlist": {
        "UIBackgroundModes": [
          "audio"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F4F4F4"
      },
      "package": "xyz.spacr.chronr"
    },
    "plugins": [
      "expo-font",
      [
        "expo-notifications",
        {
          "sounds": []
        }
      ]
    ]
  }
}